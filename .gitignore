# ================================
# Backend
# ================================

# Backend dependencies
backend/node_modules/
backend/package-lock.json

# Backend environment
backend/.env
backend/.env.local
backend/.env.*.local

# Backend logs
backend/logs/
backend/*.log
backend/npm-debug.log*

# Backend build (if any)
backend/dist/
backend/build/

# Backend temporary files
backend/temp/
backend/tmp/
backend/uploads/
backend/*.pid

